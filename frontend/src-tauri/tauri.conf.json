{
  "productName": "Yuki",
  "version": "2.0.2",
  "identifier": "app.yuki.media",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yuki — Media Suite",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/32x32.png"
    ],
    "externalBin": ["binaries/yuki-backend"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
