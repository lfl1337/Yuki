{
  "productName": "Yuki",
  "version": "3.1.0",
  "identifier": "app.yuki.media",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1423",
    "beforeBuildCommand": "npm run vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Yuki — Media Suite",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:*; img-src 'self' data: blob: https: http:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/32x32.png"
    ],
    "externalBin": ["binaries/yuki-backend"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}
